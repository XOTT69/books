    {
      "protocol": "web+chitayko",
      "url": "/?handle=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/epub+zip": [".epub"]
      }
    }
  ],
  "share_target": {
    "action": "/?action=share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
